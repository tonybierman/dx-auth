# Copy to `.env` and uncomment / fill in what you need. `docker compose`
# loads this file automatically. This covers what the example actually reads;
# for the full arium config surface (Microsoft, generic OIDC, rate limiting,
# …) see CONFIG_LEPTOS.md in the repo root.

# Host port to publish on. The container always listens on 8080.
#APP_PORT=8080

# Public URL the app uses in mail links and OAuth redirect defaults. Keep it
# as `localhost:8080` (not 127.0.0.1) so the GitHub callback URL matches
# whether you run via Docker or `cargo leptos watch`.
#PUBLIC_BASE_URL=http://localhost:8080
#FROM_EMAIL=no-reply@example.com

# SMTP — leave SMTP_HOST unset to fall back to arium's file-backed mailer,
# which drops .eml files into ./data/emails/ for inspection.
#SMTP_HOST=smtp.example.com
#SMTP_PORT=587
#SMTP_USER=postmaster@example.com
#SMTP_PASSWORD=super-secret

# First signup with this email is promoted to admin on creation.
#BOOTSTRAP_ADMIN_EMAIL=you@example.com

# Bypass the email-verification round-trip on new signups (1/true/yes/on).
# Dev only — leave unset in production.
#DX_AUTH_SKIP_EMAIL_VERIFICATION=1

# GitHub OAuth — both id and secret must be set to enable the provider.
# Register exactly this callback URL in your GitHub OAuth App (it's arium's
# built-in default): http://localhost:8080/auth/github/callback
#GITHUB_CLIENT_ID=Iv1.xxxxxxxxxxxxxxxx
#GITHUB_CLIENT_SECRET=xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# Google sign-in (OIDC). Only active when the bin is built with the
# oauth-google feature, so rebuild before `docker compose up`:
#   cargo leptos build --release --bin-features oauth-google
# Register this callback in the Google Cloud console (arium's default):
#   http://localhost:8080/auth/google/callback
#GOOGLE_CLIENT_ID=xxxxxxxxxxxx.apps.googleusercontent.com
#GOOGLE_CLIENT_SECRET=xxxxxxxxxxxxxxxxxxxxxxxx
